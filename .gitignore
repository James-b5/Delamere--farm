# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.env.local
.env.development.local
.env.test.local
.env.production.local   

# cleanup artifacts
*.bak
response.json
response2.json
migrate-result.json
migrate-result2.json
upload_out.txt
temp.jwt

# generated output
/playwright-report
/test-results
/installer_logs

# Prisma introspection output
prisma/introspected.schema.prisma

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.env*

# markdown documentation files
*.md

# test and debug files
audit-results*.json
tsc-report.txt
eslint-report.txt
next*.json
outdated.json
playwright-output.txt
test-*.js
check-*.ts
check-*.js
verify-*.ts
verify-*.js

